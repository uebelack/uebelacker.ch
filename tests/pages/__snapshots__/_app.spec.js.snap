              alt="David Übelacker"
              class="rounded-full"
              data-nimg="1"
              decoding="async"
              height="220"
              loading="lazy"
              src="/_next/image?url=%2Fdavid.jpg&w=480&q=75"
              srcset="/_next/image?url=%2Fdavid.jpg&w=256&q=75 1x, /_next/image?url=%2Fdavid.jpg&w=480&q=75 2x"
              style="color: transparent;"
              width="220"
            />
          </div>
        </div>
      </div>
